let lang = 'en';
let currentStep = 0;
const TOTAL = 7;
const selectedTiers = new Set();

function applyLang(l) {
  lang = l;
  document.querySelectorAll('.lang-btn').forEach(function(b){
    b.classList.toggle('active', b.dataset.lang === l);
  });
  document.querySelectorAll('[data-k]').forEach(function(el){
    var k = el.dataset.k;
    if (T[l][k] !== undefined) el.innerHTML = T[l][k];
  });
  document.querySelectorAll('[data-ph]').forEach(function(el){
    var k = el.dataset.ph;
    if (T[l][k] !== undefined) el.placeholder = T[l][k];
  });
  document.documentElement.lang = l;
}

function renderDots() {
  var c = document.getElementById('dots');
  c.innerHTML = '';
  if (currentStep === 0 || currentStep > TOTAL) { c.style.display = 'none'; return; }
  c.style.display = 'flex';
  for (var i = 1; i <= TOTAL; i++) {
    var d = document.createElement('span');
    d.className = 'dot' + (i < currentStep ? ' done' : i === currentStep ? ' active' : '');
    c.appendChild(d);
  }
}

function setProgress(n) {
  var pct = n === 0 ? 0 : n > TOTAL ? 100 : Math.round((n / TOTAL) * 100);
  document.getElementById('progressBar').style.width = pct + '%';
}

function goStep(n) {
  document.querySelectorAll('.step').forEach(function(s){ s.classList.remove('active'); });
  var target = document.getElementById(n > TOTAL ? 'step-success' : 'step-' + n);
  if (target) target.classList.add('active');
  currentStep = n;
  renderDots();
  setProgress(n);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function setFieldError(fieldId, hasError) {
  var f = document.getElementById(fieldId);
  if (!f) return;
  f.classList.toggle('has-error', hasError);
}

function validate(step) {
  var ok = true;

  function reqField(wrapId, inputId) {
    var val = (document.getElementById(inputId) || {}).value || '';
    var bad = !val.trim();
    setFieldError(wrapId, bad);
    if (bad) ok = false;
  }
  function emailField(wrapId, inputId) {
    var val = (document.getElementById(inputId) || {}).value || '';
    var bad = !val.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
    setFieldError(wrapId, bad);
    if (bad) ok = false;
  }
  function urlField(wrapId, inputId) {
    var val = (document.getElementById(inputId) || {}).value || '';
    var bad = !val.trim() || !/^https?:\/\/.+/.test(val);
    setFieldError(wrapId, bad);
    if (bad) ok = false;
  }
  function groupReq(groupId) {
    var el = document.getElementById(groupId);
    if (!el) return;
    var checked = el.querySelector('input:checked');
    if (!checked) { el.classList.add('group-error'); ok = false; }
    else el.classList.remove('group-error');
  }
  function checkboxGroupReq(groupId) {
    var el = document.getElementById(groupId);
    if (!el) return;
    var checked = el.querySelectorAll('input:checked').length;
    if (checked === 0) { el.classList.add('group-error'); ok = false; }
    else el.classList.remove('group-error');
  }

  if (step === 1) {
    reqField('f-am-name', 'am_name');
    emailField('f-am-email', 'am_email');
    reqField('f-am-tg', 'am_tg');
  }
  if (step === 2) {
    reqField('f-brand-name', 'brand_name');
    urlField('f-brand-url', 'brand_url');
    reqField('f-brand-date', 'brand_date');
  }
  if (step === 3) {
    groupReq('license-group');
    groupReq('software-group');
    urlField('f-aff-url', 'aff_url');
  }
  if (step === 4) {
    checkboxGroupReq('sources-group');
    if (selectedTiers.size === 0) {
      document.getElementById('tier-error').style.display = 'block'; ok = false;
    } else {
      document.getElementById('tier-error').style.display = 'none';
    }
    reqField('f-geo-list', 'geo_list');
    groupReq('deal-structure-group');
    reqField('f-best-deal', 'best_deal');
    checkboxGroupReq('seo-approaches-group');
    groupReq('ftd-group');
  }
  if (step === 5) {
    groupReq('exp-group');
    checkboxGroupReq('retention-group');
  }
  if (step === 6) {
    groupReq('payment-terms-group');
    groupReq('payment-method-group');
  }
  return ok;
}

function collectData() {
  function v(id) { return (document.getElementById(id) || {}).value || ''; }
  function radio(name) { var el = document.querySelector('input[name="' + name + '"]:checked'); return el ? el.value : ''; }
  function checks(groupId) { return Array.from(document.querySelectorAll('#' + groupId + ' input:checked')).map(function(i){ return i.value; }).join(', '); }
  return {
    'Submitted At':       new Date().toISOString(),
    'Language':           lang.toUpperCase(),
    'AM Name':            v('am_name'),
    'AM Email':           v('am_email'),
    'AM Telegram':        v('am_tg'),
    'Brand Name':         v('brand_name'),
    'Brand URL':          v('brand_url'),
    'Brand Launch Date':  v('brand_date'),
    'Brand Book Link':    v('brand_book_link'),
    'License':            radio('license'),
    'License Note':       v('license_explain_txt'),
    'Whitelabel Software':radio('software'),
    'Software Other':     v('software_other_txt'),
    'Affiliate URL':      v('aff_url'),
    'API':                radio('api'),
    'Fixed Fees':         radio('fixed_fees'),
    'Targeted Sources':   checks('sources-group'),
    'Tiers':              Array.from(selectedTiers).join(', '),
    'GEOs':               v('geo_list'),
    'Deal Structure':     radio('deal_structure'),
    'Avg CR (SEO)':       radio('cr_seo'),
    'CR SEO GEO Note':    v('cr_geo'),
    'Avg CR (Social+)':   radio('cr_social'),
    'Best Deal Proposal': v('best_deal'),
    'SEO Approaches':     checks('seo-approaches-group'),
    'SEO Approaches Detail': v('seo_approaches_detail'),
    'FTD Amount':         radio('ftd_amount'),
    'Experience':         radio('experience'),
    'Retention':          checks('retention-group'),
    'Retention Other':    v('retention_other'),
    'Payback Period':     radio('payback_period'),
    'Payment Terms':      radio('payment_terms'),
    'Payment Method':     radio('payment_method'),
    'Payment Method Other': v('payment_method_other_txt'),
    'IO Required':        radio('io_required'),
    'Comment':            v('comment')
  };
}

async function submitForm() {
  var btn = document.getElementById('submit-btn');
  btn.classList.add('loading');
  btn.disabled = true;
  var data = collectData();
  await sendSheets(data);
  btn.classList.remove('loading');
  btn.disabled = false;
  goStep(TOTAL + 1);
}

async function sendSheets(data) {
  try { await fetch(SHEET_URL, { method:'POST', body: JSON.stringify(data) }); } catch(e) {}
}

function showNotif(msg) {
  var n = document.getElementById('notif');
  document.getElementById('notif-text').textContent = msg;
  n.classList.add('show');
  setTimeout(function(){ n.classList.remove('show'); }, 3000);
}

document.addEventListener('DOMContentLoaded', function() {

  document.querySelectorAll('.lang-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { applyLang(btn.dataset.lang); });
  });

  document.getElementById('btn-start').addEventListener('click', function() { goStep(1); });

  document.querySelectorAll('[data-goto]').forEach(function(btn) {
    btn.addEventListener('click', function() { goStep(parseInt(btn.dataset.goto)); });
  });

  document.querySelectorAll('[data-next]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var cur = parseInt(btn.dataset.next);
      if (validate(cur)) goStep(cur + 1);
      else showNotif(T[lang].err_required);
    });
  });

  document.getElementById('submit-btn').addEventListener('click', submitForm);

  document.querySelectorAll('.choice-item[data-radio]').forEach(function(item) {
    item.addEventListener('click', function() {
      var name = item.dataset.radio;
      var val  = item.dataset.val;
      document.querySelectorAll('.choice-item[data-radio="' + name + '"]').forEach(function(el) {
        el.classList.remove('selected');
      });
      item.classList.add('selected');
      var inp = item.querySelector('input[type=radio]');
      if (inp) inp.checked = true;
      if (name === 'license') {
        document.getElementById('license-explain').classList.toggle('visible', val === 'N/A' || val === 'Other');
      }
      if (name === 'software') {
        document.getElementById('software-explain').classList.toggle('visible', val === 'Other');
      }
      if (name === 'payment_method') {
        document.getElementById('payment-method-explain').classList.toggle('visible', val === 'Other');
      }
      var grp = document.getElementById(name + '-group');
      if (grp) grp.classList.remove('group-error');
    });
  });

  document.querySelectorAll('.tier-pill').forEach(function(pill) {
    pill.addEventListener('click', function() {
      var tier = pill.dataset.tier;
      if (selectedTiers.has(tier)) { selectedTiers.delete(tier); pill.classList.remove('active'); }
      else { selectedTiers.add(tier); pill.classList.add('active'); }
    });
  });

  document.querySelectorAll('[data-checkbox]').forEach(function(item) {
    item.addEventListener('click', function() {
      item.classList.toggle('selected');
      var cb = item.querySelector('input[type=checkbox]');
      if (cb) cb.checked = item.classList.contains('selected');
      var grp = item.closest('.check-grid, .choice-group');
      if (grp) grp.classList.remove('group-error');
    });
  });

  applyLang('en');
  renderDots();
  setProgress(0);
});
</script>
</body>
</html>
